<ContentDialog
    x:Class="GameSpaceManager.Presentation.Shared.ProgressDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Progress"
    Width="400"
    Height="180"
    Background="White"
    PrimaryButtonText="Cancel"
    IsPrimaryButtonEnabled="False">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock x:Name="StatusText" Text="Processing..." FontSize="16" Margin="0,0,0,10"/>
            <ProgressBar x:Name="ProgressBar" Height="30" Minimum="0" Maximum="100" Value="0"/>
        </StackPanel>
    </Grid>
</ContentDialog>

